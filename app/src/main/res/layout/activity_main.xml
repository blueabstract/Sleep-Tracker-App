<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sleep Tracker By SUBARNO"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track. Rest. Recover."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp"/>

        <!-- Sleep Stage Card -->
        <LinearLayout
            android:id="@+id/cardSleepStage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_rounded"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvStageEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙"
                android:textSize="48sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvSleepStage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Awaiting Sleep"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <!-- Chronometer Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_rounded_dark"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ELAPSED"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp"/>

            <com.example.sleeptracker.Chronometer
                android:id="@+id/chronometer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="@color/accent_blue"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Progress -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GOAL PROGRESS"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <ProgressBar
            android:id="@+id/progressSleep"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_bar_style"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvGoalStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal: 8h 00m"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp"/>

        <!-- Start / Stop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="▶ Start"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/btn_start"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnStop"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="■ Stop"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/btn_stop"
                android:layout_marginStart="8dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- Reset / Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="↺ Reset"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/btn_reset"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⚙ Settings"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/btn_settings"
                android:layout_marginStart="8dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- Summary Card -->
        <LinearLayout
            android:id="@+id/layoutSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_rounded_dark"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SLEEP HISTORY"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAvgSleep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Avg Sleep: —"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="@color/divider"/>

                <TextView
                    android:id="@+id/tvLastSleep"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Last: —"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvTotalSessions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sessions: 0"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_gravity="center_horizontal"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>